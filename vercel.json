{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/notes/:slug", "destination": "/notes" }
  ],
  "redirects": [
    { "source": "/glossary", "destination": "/notes", "permanent": true },
    { "source": "/glossary/:slug", "destination": "/notes/:slug", "permanent": true }
  ]
}
